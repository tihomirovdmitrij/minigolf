{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"formatter": {
		"enabled": true,
		"formatWithErrors": true,
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"includes": ["**", "!node_modules", "!.next", "!dist", "!coverage", "!.idea", "!.vscode"]
	}
}
